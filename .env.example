# AfroCrave Kitchen - Environment Variables Template
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub

# Staff passwords
VITE_PASS_ADMIN=your_admin_password_here
VITE_PASS_KITCHEN=your_kitchen_password_here
VITE_PASS_MANAGER=your_manager_password_here
VITE_PASS_RIDER=your_rider_password_here

# Kitchen contact
VITE_KITCHEN_WA=44xxxxxxxxxx
VITE_KITCHEN_PHONE=+44 7xxx xxxxxx

# Supabase
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
